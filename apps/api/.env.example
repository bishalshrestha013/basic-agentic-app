# OpenAI API key (required). Works with any OpenAI-compatible provider.
OPENAI_API_KEY=sk-your-key-here

# Optional: point at an OpenAI-compatible gateway such as OpenRouter.
# Leave unset to use the official OpenAI API.
# OPENAI_BASE_URL=https://openrouter.ai/api/v1

# Optional: override the model. Defaults to gpt-4o.
# On OpenRouter the id is namespaced, e.g. openai/gpt-4o.
# OPENAI_MODEL=gpt-4o

# Optional: SQLite database file path. Defaults to expenses.db.
# DB_PATH=expenses.db
